{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iroharness.dev/protocols/user.schema.json",
  "title": "IroHarness User",
  "type": "object",
  "required": ["id", "displayName", "role", "identities", "permissions", "relationship"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "enum": ["owner", "developer", "moderator", "member", "fan", "anonymous"]
    },
    "identities": {
      "type": "object",
      "description": "Platform user IDs keyed by platform name, such as youtube, discord, slack, vscode, browser.",
      "additionalProperties": {
        "type": "string"
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relationship": {
      "type": "string",
      "enum": ["owner", "developer", "trusted", "member", "public"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "permissionOverrides": {
      "type": "array",
      "description": "Resolved permission override rows for this user when returned from a registry snapshot.",
      "items": {
        "type": "object",
        "required": ["userId", "permission", "effect", "scope"],
        "properties": {
          "userId": {
            "type": "string"
          },
          "permission": {
            "type": "string"
          },
          "effect": {
            "type": "string",
            "enum": ["allow", "deny"]
          },
          "scope": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
